# PROverify frontend (Vite) environment variables.
# Copy this file to `frontend/.env` for local overrides. Never commit `.env`.
#
# Vite only exposes variables prefixed with `VITE_` to client code via
# `import.meta.env`. Anything else in this file is ignored by the build.

# Base URL of the PROverify backend API.
# - Leave UNSET in production (the frontend is served by FastAPI on the
#   same origin and will fall back to relative URLs).
# - Set to http://localhost:8000 if you run the backend on a different host
#   during local development.
# VITE_API_BASE=http://localhost:8000
